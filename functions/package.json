{
  "name": "antigravity-functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --passWithNoTests",
    "test:smoke": "npm run build && node lib/smoke-tests.js",
    "test:emulator": "npx firebase emulators:start --only functions,firestore",
    "test:all": "jest && npm run test:smoke"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/genai": "^1.44.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2",
    "nodemailer": "^8.0.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^7.0.11",
    "firebase-functions-test": "^3.4.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.7.0"
  },
  "private": true
}
