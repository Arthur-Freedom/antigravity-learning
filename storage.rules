rules_version = '2';

// ── Firebase Storage Security Rules ─────────────────────────────────────
// Protects file uploads so users can only manage their own profile pictures.

service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile Pictures ──────────────────────────────────────────────────
    // Path: profilePictures/{userId}/avatar.{ext}
    // - READ: Anyone authenticated can view profile pictures (for leaderboard)
    // - WRITE: Only the file owner can upload/delete their own picture
    // - Size limit: 5 MB
    // - Allowed types: JPEG, PNG, WebP, GIF
    match /profilePictures/{userId}/{fileName} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ── Default deny ────────────────────────────────────────────────────
    // Everything else is locked down.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
