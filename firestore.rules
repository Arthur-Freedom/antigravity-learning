rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────

    function hasOnlyAllowedFields(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    function incomingData() {
      return request.resource.data;
    }

    // ── User profiles ───────────────────────────────────────────────────
    // Any authenticated user can READ all profiles (needed for leaderboard).
    // Each user can ONLY WRITE their own document (with schema validation).
    match /users/{userId} {

      allow read: if request.auth != null;

      // ────── Create: first-time profile setup ──────
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && isValidUserProfileCreate();

      // ────── Update: returning user updates ──────
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && isValidUserProfileUpdate();

      // ────── Delete: not allowed ──────
      allow delete: if false;

      // ── Schema validation: CREATE ─────────────────────────────────────
      function isValidUserProfileCreate() {
        let allowed = ['displayName', 'email', 'photoURL',
                       'theme', 'quizProgress',
                       'quizScore', 'quizTotal', 'completedAll',
                       'createdAt', 'updatedAt'];
        return hasOnlyAllowedFields(allowed)
            && isValidDisplayName(incomingData().displayName)
            && isValidEmail(incomingData().email)
            && isValidPhotoURL(incomingData().photoURL)
            && isValidTheme(incomingData().theme)
            && incomingData().quizProgress is map
            && isValidQuizScore(incomingData().quizScore)
            && isValidQuizTotal(incomingData().quizTotal)
            && incomingData().completedAll is bool
            && incomingData().createdAt == request.time
            && incomingData().updatedAt == request.time;
      }

      // ── Schema validation: UPDATE ─────────────────────────────────────
      function isValidUserProfileUpdate() {
        let allowed = ['displayName', 'email', 'photoURL', 'customPhotoURL',
                       'theme', 'quizProgress',
                       'quizScore', 'quizTotal', 'completedAll',
                       'createdAt', 'updatedAt', 'congratsEmailSentAt'];
        return hasOnlyAllowedFields(allowed)
            && incomingData().updatedAt == request.time
            && incomingData().createdAt == resource.data.createdAt
            && isValidDisplayName(incomingData().displayName)
            && isValidEmail(incomingData().email)
            && isValidPhotoURL(incomingData().photoURL)
            && isValidTheme(incomingData().theme)
            && isValidQuizProgress(incomingData().quizProgress)
            && isValidQuizScore(incomingData().quizScore)
            && isValidQuizTotal(incomingData().quizTotal)
            && incomingData().completedAll is bool;
      }

      // ── Per-field validators ──────────────────────────────────────────

      function isValidDisplayName(val) {
        return val is string && val.size() >= 1 && val.size() <= 100;
      }

      function isValidEmail(val) {
        return val is string && val.size() <= 320;
      }

      function isValidPhotoURL(val) {
        return val == null || (val is string && val.size() <= 2048);
      }

      function isValidTheme(val) {
        return val is string && (val == 'light' || val == 'dark');
      }

      function isValidQuizProgress(val) {
        return val is map;
      }

      function isValidQuizScore(val) {
        return val is int && val >= 0 && val <= 100;
      }

      function isValidQuizTotal(val) {
        return val is int && val >= 0 && val <= 100;
      }
    }

    // ── Mail collection (Cloud Functions only) ──────────────────────────
    // The congratulations email trigger writes here using the Admin SDK
    // (bypasses these rules). Client-side access is fully denied.
    match /mail/{mailId} {
      allow read, write: if false;
    }

    // ── Default deny ────────────────────────────────────────────────────
    // Everything else is locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
