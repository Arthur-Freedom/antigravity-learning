rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ───────────────────────────────────────────────────
    // READ: Anyone can view profiles (leaderboard is public).
    //        Admins with custom claim can also read (for analytics).
    // WRITE: Only the profile owner can write their own document.
    //        Cloud Functions (Admin SDK) bypass these rules entirely.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Admin-only collections ──────────────────────────────────────────
    // Admins can read audit collections for debugging.
    match /audit/{docId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Mail collection (Cloud Functions only) ──────────────────────────
    // The congratulations email trigger writes here using the Admin SDK
    // (bypasses these rules). Client-side access is fully denied.
    match /mail/{mailId} {
      allow read, write: if false;
    }

    // ── Extension mail (Trigger Email extension) ────────────────────────
    // Docs written here by Admin SDK → extension sends the email.
    match /ext_mail/{mailId} {
      allow read, write: if false;
    }

    // ── Rate limits (Cloud Functions only) ───────────────────────────────
    // AI hint rate-limiting counters. Managed exclusively by Cloud Functions.
    match /rateLimits/{document=**} {
      allow read, write: if false;
    }

    // ── Config collection (Cloud Functions + Admin) ─────────────────────
    // Dynamic configuration (e.g. valid quiz topics).
    // Cloud Functions read via Admin SDK (bypasses rules).
    // Admins can read for inspection. No client writes.
    match /config/{docId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Default deny ────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
